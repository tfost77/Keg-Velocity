# Google Sheets — the ID from your sheet's URL
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=

# Google auth — choose one of the three options below:
#
# Option A: Service account key (preferred for Streamlit Cloud)
#   Paste the full contents of your service account JSON as a single-line string.
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Option B: OAuth refresh token (use this if org policy blocks service account keys)
#   Find these values in your token.json (refresh_token) and credentials.json (client_id/secret).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
#
# Option C: OAuth via file (local dev only)
#   Place credentials.json in the project root. token.json is created on first run.

# Gmail (only needed if using the local email workflow)
GMAIL_SENDER=you@yourdomain.com
GMAIL_RECIPIENT=you@yourdomain.com  # comma-separated for multiple recipients

# Streamlit Cloud config (only needed if config.json is not committed to the repo)
# Paste the full contents of config.json as a single-line JSON string.
INVENTORY_CONFIG=
