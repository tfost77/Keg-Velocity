# Google Sheets — the ID from your sheet's URL
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=

# Google auth — choose one:
#
# Option A: Service account (required for Streamlit Cloud / headless use)
#   Paste the entire contents of your service account key JSON as a single-line string.
#   In Streamlit Cloud, add this under Settings → Secrets instead of .env.
GOOGLE_SERVICE_ACCOUNT_JSON=
#
# Option B: OAuth (local dev only)
#   Download credentials.json from Google Cloud Console and place it in the project root.
#   token.json is created automatically on first run.

# Gmail (only needed if using the local email workflow)
GMAIL_SENDER=you@yourdomain.com
GMAIL_RECIPIENT=you@yourdomain.com  # comma-separated for multiple recipients

# Streamlit Cloud config (only needed if config.json is not committed to the repo)
# Paste the full contents of config.json as a single-line JSON string.
INVENTORY_CONFIG=
